datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  role     String   // ADMIN, OPERATOR, FINANCIAL, AUDITOR
  name     String
}

model Product {
  id               Int       @id @default(autoincrement())
  sku              String    @unique
  name             String
  type             String    // BEAN, GROUND
  presentation_g   Int       // Presentación en gramos
  packaging_unit   String    // e.g. "Bolsa", "Caja", "Unidad"
  unit             String    @default("g") // g, kg, ud
  category         String?
  brand            String?
  active           Boolean   @default(true)
  cost_standard    Float?    
  created_at       DateTime  @default(now())
  
  balances       InventoryBalance[]
  ledger         InventoryLedger[]
  doc_lines      InventoryDocumentLine[]
}

model Warehouse {
  id             Int      @id @default(autoincrement())
  name           String
  location       String?
  manager_id     Int?
  type           String   // PRODUCTION, STORE, THIRD_PARTY
  active         Boolean  @default(true)
  color          String   @default("#c6a052")

  balances       InventoryBalance[]
  docs_from      InventoryDocument[] @relation("FromWarehouse")
  docs_to        InventoryDocument[] @relation("ToWarehouse")
}

model InventoryBalance {
  id             Int      @id @default(autoincrement())
  product_id     Int
  warehouse_id   Int
  lot            String   @default("SIN-LOTE")
  qty_on_hand    Float    @default(0)
  avg_cost       Float    @default(0)
  value_total    Float    @default(0)
  updated_at     DateTime @updatedAt

  product        Product   @relation(fields: [product_id], references: [id])
  warehouse      Warehouse @relation(fields: [warehouse_id], references: [id])

  @@unique([product_id, warehouse_id, lot])
}

model InventoryDocument {
  id                Int      @id @default(autoincrement())
  doc_type          String   // IN, OUT, TR, AJ
  document_number   String   @unique
  status            String   // DRAFT, APPLIED, CANCELLED
  warehouse_from_id Int?
  warehouse_to_id   Int?
  third_party_id    Int?
  date              DateTime
  notes             String?
  created_by        Int
  approved_by       Int?
  attachment_url    String?

  warehouse_from    Warehouse? @relation("FromWarehouse", fields: [warehouse_from_id], references: [id])
  warehouse_to      Warehouse? @relation("ToWarehouse", fields: [warehouse_to_id], references: [id])

  lines             InventoryDocumentLine[]
}

model InventoryDocumentLine {
  id            Int      @id @default(autoincrement())
  document_id   Int
  product_id    Int
  qty           Float
  unit_cost     Float?
  total_cost    Float?
  unit_sale     Float?
  total_sale    Float?
  lot           String?

  document      InventoryDocument @relation(fields: [document_id], references: [id])
  product       Product @relation(fields: [product_id], references: [id])
}

model InventoryLedger {
  id               Int      @id @default(autoincrement())
  timestamp        DateTime @default(now())
  product_id       Int
  warehouse_id     Int
  movement_type    String   // IN, OUT
  doc_id           Int
  qty_in           Float    @default(0)
  qty_out          Float    @default(0)
  balance_qty      Float
  unit_cost        Float
  avg_cost_after   Float
  value_after      Float
  lot              String   @default("SIN-LOTE")
  created_by       Int

  product          Product  @relation(fields: [product_id], references: [id])
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  entity        String
  entity_id     Int
  action        String   // CREATE, UPDATE, DELETE, CANCEL
  old_value     String?  // JSON stringified
  new_value     String?  // JSON stringified
  user_id       Int
  timestamp     DateTime @default(now())
  ip            String?
}
